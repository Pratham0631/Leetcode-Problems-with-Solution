

public static void main(String[] args) {
		// gcd of 12 and 4
		System.out.println(gcd(12, 4));
		
		// lcm of 12 and 4
		System.out.println((12 * 4) /gcd(12, 4));
	}

  // BEST -> No Exception
	public static int gcd(int a, int b){
	    if(b == 0) return a;
	    return gcd(b, a%b);
	}

  // Gives Exception (divide by zero if initially entered b == 0)
  public static int gcd(int a, int b){
	    if(a%b == 0) return b;
	    return gcd(b, a%b);
	}
