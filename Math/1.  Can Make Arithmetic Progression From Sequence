=>  A sequence of numbers is called an arithmetic progression if the difference between any two consecutive elements is the same.
    Given an array of numbers arr, return true if the array can be rearranged to form an arithmetic progression. Otherwise, return   false.

    Example 1:
      Input: arr = [3,5,1]
      Output: true
      Explanation: We can reorder the elements as [1,3,5] or [5,3,1] with differences 2 and -2 respectively, between each consecutive elements.
      
    Example 2:
      Input: arr = [1,2,4]
      Output: false
      Explanation: There is no way to reorder the elements to obtain an arithmetic progression.

    Constraints:
      2 <= arr.length <= 1000
      -106 <= arr[i] <= 106




=>  MY CODE
    public boolean canMakeArithmeticProgression(int[] arr) {
        int n = arr.length;

        Arrays.sort(arr);
        int initDiff = arr[1] - arr[0];

        for(int i = 2; i < n; i++){
            if(Math.abs(arr[i] - arr[i - 1]) != initDiff){
                return false;
            }
        }

        return true;
    }




=>  OPTIMIZED O(N) Time, O(N) Space
    public boolean canMakeArithmeticProgression(int[] arr) {
        int n = arr.length;

        int max = Integer.MIN_VALUE;
        int min = Integer.MAX_VALUE;

        Set<Integer> set = new HashSet<>();

        for(int e : arr){
            max = Math.max(max, e);
            min = Math.min(min, e);
            set.add(e);
        }

        // a + (n - 1) * d = last term || min + (n - 1) * d = max
        // d = (max - min) / (n - 1)
        if((max - min) % (n - 1) != 0) return false; // if fraction
        int apDiff = (max - min) / (n - 1);

        for(int i = 0; i < n; i++){
            int num = min + (i * apDiff);
            if(!set.contains(num)){
                return false;
            }
        }
        
        return true;
    }




=> SUPER OPTIMIZED O(N) Time, O(N) Space
   public boolean canMakeArithmeticProgression(int[] arr){
        int n = arr.length;

        int max = Integer.MIN_VALUE;
        int min = Integer.MAX_VALUE;

        for(int e : arr){
            max = Math.max(max, e);
            min = Math.min(min, e);
        }

        if((max - min) % (n - 1) != 0) return false; // if fraction
        int d = (max - min) / (n - 1);

        int i = 0;

        while(i < n){

            int currValAtI = arr[i];
            int correctValAtI = min + (i * d);

            if(currValAtI != correctValAtI){

                if((currValAtI - min) % d != 0) return false; // check fraction generation

                int correctValOfCurr = (currValAtI - min) / d;

                if(arr[correctValOfCurr] == currValAtI) return false; // infinite check condition

                // Swap
                int temp = arr[i];
                arr[i] = arr[correctValOfCurr];
                arr[correctValOfCurr] = temp;

            }
            else{
                i++;
            }
        }

        return true;
    }
   
    
